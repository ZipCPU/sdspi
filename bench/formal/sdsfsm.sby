[tasks]
prf
cvr

[options]
prf: mode prove
prf: depth 6		## Takes less than 1min
cvr: mode cover
cvr: depth 70		## Takes about 6min

[engines]
smtbmc

[script]
read -formal sdsfsm.v
--pycode-begin--
cmd = "hierarchy -top sdsfsm"
output(cmd)
--pycode-end--
prep -top sdsfsm

[files]
../../rtl/sdslave/sdsfsm.v
